{
  "name": "astrape-motors-site",
  "version": "1.0.0",
  "description": "Static landing page for Astrape Motors",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:js": "eslint .",
    "lint:html": "htmlhint \"**/*.html\"",
    "lint:css": "stylelint \"assets/**/*.css\"",
    "lint": "run-p lint:*",
    "format": "prettier . --write",
    "check-format": "prettier . --check",
    "quality": "npm run check-format && npm run lint && npm run build",
    "deploy:ftp": "node scripts/deploy-ftp.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "htmlhint": "^1.9.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "dotenv": "^17.4.2"
  }
}
